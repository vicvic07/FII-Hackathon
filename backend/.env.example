PORT=4000
COMPATIBILITY_PORT=4001
ALLOWED_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5500/frontend/
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
